# Required: long random hex string for signing sessions
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# Optional: path to the SQLite database file (default: zerotrust.db)
DATABASE_URL=zerotrust.db

# Optional: set to true for debug mode — NEVER in production
FLASK_DEBUG=false
